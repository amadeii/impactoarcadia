NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SESSION_SECRET=troque_por_um_valor_forte
CRYPTO_SECRET=troque_por_outro_valor_forte
AUTH_MODE=local
DISABLE_OIDC=true
DISABLE_LLM_HEALTH_PROBE=true
DB_POOL_MAX=20

# ControlPlus Geral - contrato novo server-to-server
CONTROL_PLUS_URL=http://127.0.0.1:8000
CONTROL_PLUS_SUPERADMIN_TOKEN=TOKEN_DO_CONTROLPLUS
CONTROL_PLUS_EMPRESA_ID=1
CONTROL_PLUS_TIMEOUT_MS=15000

# Integracoes legadas Plus/Control Plus, se ainda forem usadas no projeto
# Ex.: NFSe, DF-e, download XML e fiscal antigo
# PLUS_URL=http://127.0.0.1:8080
# PLUS_API_TOKEN=TOKEN_LEGADO
